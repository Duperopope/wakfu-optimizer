print(f'FPS interne: {engine.fps:.1f}', flush=True)

if count > 0:
    print('\n--- Test 2: resize 3s ---', flush=True)
    t0 = time.perf_counter()
    n = 0
    lid = 0
    while time.perf_counter() - t0 < 3.0:
        bgra, fid, w, h = engine.get_frame()
        if bgra is not None and fid != lid:
            lid = fid
            cv2.resize(bgra, (480,270), interpolation=cv2.INTER_NEAREST)
