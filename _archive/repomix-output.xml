print(f'Resolution: {engine.width}x{engine.height}', flush=True)
print('Warmup 2s...', flush=True)
time.sleep(2)

print('\n--- Test 1: get_frame 3s ---', flush=True)
t0 = time.perf_counter()
count = 0
nulls = 0
lid = 0
while time.perf_counter() - t0 < 3.0:
    try:
        bgra, fid, w, h = engine.get_frame()
    except Exception as e:
        print(f'ERREUR get_frame: {e}', flush=True)
