"""Auto-decouverte et chargement des modules.

NE PAS MODIFIER une fois verrouille.
Version: 1.0.0

Scanne le dossier modules/ et charge automatiquement tout module
qui exporte une classe heritant de ModuleBase.
"""
from __future__ import annotations
import importlib
import pkgutil
from pathlib import Path
from typing import Type
from vision_automator_v5.module_base import ModuleBase
from vision_automator_v5.shared.logger import get_logger

log = get_logger("registry")


def discover_modules() -> list[Type[ModuleBase]]:
    """Scanne modules/ et retourne les classes de modules trouvees."""
    modules_path = Path(__file__).parent / "modules"
    found: list[Type[ModuleBase]] = []

    for finder, name, ispkg in pkgutil.iter_modules([str(modules_path)]):
        if not ispkg:
            continue
        try:
            mod = importlib.import_module(f"vision_automator_v5.modules.{name}")
            # Chercher un attribut 'Module' ou 'module_class'
            cls = getattr(mod, "Module", None) or getattr(mod, "module_class", None)
            if cls is None:
                # Chercher dans module.py
                try:
                    sub = importlib.import_module(f"vision_automator_v5.modules.{name}.module")
                    cls = getattr(sub, "Module", None) or getattr(sub, "module_class", None)
                except ImportError:
                    pass

            if cls and isinstance(cls, type) and issubclass(cls, ModuleBase):
                found.append(cls)
                log.info(f"Decouvert: {cls.name.fget(cls)} v{cls.version.fget(cls)} ({name})")
            else:
                log.warning(f"Module {name}: pas de classe ModuleBase trouvee")

        except Exception as e:
            log.error(f"Erreur chargement module {name}: {e}")

    # Trier par nom de dossier (m01_, m02_, ...)
    found.sort(key=lambda c: c.__module__)
    return found
