"""Contrat de base pour tous les modules.

NE PAS MODIFIER une fois verrouille.
Version: 1.0.0

Chaque module dans modules/ doit heriter de ModuleBase
et implementer les methodes abstraites.
"""
from __future__ import annotations
from abc import ABC, abstractmethod
from typing import Any


class ModuleBase(ABC):
    """Interface que chaque module doit implementer."""

    @property
    @abstractmethod
    def name(self) -> str:
        """Identifiant unique du module (ex: 'capture')."""

    @property
    @abstractmethod
    def version(self) -> str:
        """Version du module (ex: '1.0.0')."""

    @property
    def description(self) -> str:
        """Description courte du module."""
        return ""

    @property
    def icon(self) -> str:
        """Caractere unicode pour l'icone dans la sidebar."""
        return "+"

    @abstractmethod
    def initialize(self, hub: Any, config: dict) -> None:
        """Appele une fois au chargement. Recoit le hub et la config globale."""

    @abstractmethod
    def build_ui(self, parent: int | str) -> None:
        """Construit l'UI du module dans le conteneur DearPyGui fourni."""

    def on_show(self) -> None:
        """Appele quand le module devient visible (onglet selectionne)."""
        pass

    def on_hide(self) -> None:
        """Appele quand le module est masque."""
        pass

    def cleanup(self) -> None:
        """Appele a la fermeture de l'app. Liberer les ressources."""
        pass
