"""Moteur WGC v3.0.0 FINAL — ascontiguousarray dans le callback.

Le buffer WGC a un stride padding (6912 vs 6892).
On force ascontiguousarray + copy UNE SEULE FOIS dans le callback.
Tout le reste recoit un array propre C-contiguous.
"""
from __future__ import annotations
import threading, time
import numpy as np
import win32gui
from vision_automator_v5.shared.logger import get_logger

log = get_logger("capture_engine")

try:
    from windows_capture import WindowsCapture, Frame, InternalCaptureControl
    HAS_WGC = True
except ImportError:
    HAS_WGC = False

class CaptureEngine:
    def __init__(self):
        self._lock = threading.Lock()
        self._bgra = None
        self._fid = 0
        self._w = 0
        self._h = 0
        self._fps = 0.0
        self._running = False
        self._thread = None
        self._fpsc = 0
        self._fpst = 0.0
        self._title = ""
        self._ready = threading.Event()

    @property
    def running(self): return self._running
    @property
    def width(self): return self._w
    @property
    def height(self): return self._h
    @property
    def fps(self): return self._fps
    @property
    def frame_id(self): return self._fid

    def list_windows(self):
        r = []
        def cb(hwnd, _):
            if win32gui.IsWindowVisible(hwnd):
                t = win32gui.GetWindowText(hwnd)
                if t.strip(): r.append((hwnd, t))
        win32gui.EnumWindows(cb, None)
        r.sort(key=lambda x: x[1].lower())
        return r

    def start(self, title):
        if not HAS_WGC: return False
        if self._running: self.stop()
        self._title = title
        self._running = True
        self._bgra = None
        self._fid = 0
        self._fpsc = 0
        self._fpst = time.perf_counter()
        self._ready.clear()
        self._thread = threading.Thread(target=self._run, daemon=True, name="wgc")
        self._thread.start()
        ok = self._ready.wait(timeout=5.0)
        if ok: log.info(f"GO: {title} ({self._w}x{self._h})")
        else: log.warning("Timeout")
        return ok

    def stop(self):
        self._running = False
        if self._thread and self._thread.is_alive():
            self._thread.join(timeout=3.0)
        self._thread = None
        log.info("Stop")

    def get_frame(self):
        with self._lock:
            return self._bgra, self._fid, self._w, self._h

    def _run(self):
        ref = self
        try:
            cap = WindowsCapture(
                cursor_capture=None, draw_border=None,
                monitor_index=None, window_name=self._title,
            )
            @cap.event
            def on_frame_arrived(frame: Frame, cc: InternalCaptureControl):
                if not ref._running:
                    cc.stop()
                    return
                raw = frame.frame_buffer
                if raw is None or raw.size == 0:
                    return
                # FIX: le buffer WGC a du stride padding
                # ascontiguousarray copie et supprime le padding
                clean = np.ascontiguousarray(raw)
                with ref._lock:
                    ref._bgra = clean
                    ref._fid += 1
                    ref._w = frame.width
                    ref._h = frame.height
                if not ref._ready.is_set():
                    ref._ready.set()
                ref._fpsc += 1
                now = time.perf_counter()
                dt = now - ref._fpst
                if dt >= 1.0:
                    ref._fps = ref._fpsc / dt
                    ref._fpsc = 0
                    ref._fpst = now
            @cap.event
            def on_closed():
                ref._running = False
            cap.start()
        except Exception as e:
            log.error(f"WGC: {e}")
            self._running = False
