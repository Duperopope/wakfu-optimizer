for h, t in wins:
    low = t.lower()
    if 'wakfu' in low and 'visual studio' not in low and 'code' not in low:
        target = t
        hwnd = h
        break
if not target:
    for h, t in wins:
        if 'madame' in t.lower():
            target = t
            hwnd = h
            break

if not target:
    print('ERREUR: pas de fenetre Wakfu')
