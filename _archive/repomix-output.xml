"""Module Detection — template matching sur les frames capturees.

Version: 1.0.0

Ecoute: frame.new (depuis m01_capture)
Emet:   detection.result -> list[DetectionResult]
        detection.stats  -> dict {fps, count, templates}

UI: panneau de config (threshold, intervalle, dossier templates)
    + tableau des detections en temps reel.
"""
from __future__ import annotations
import threading
import time
import dearpygui.dearpygui as dpg

from vision_automator_v5.module_base import ModuleBase
from vision_automator_v5.shared.bus import bus
from vision_automator_v5.shared.logger import get_logger
from vision_automator_v5.shared.types import FrameData, DetectionResult
from vision_automator_v5.modules.m02_detection.detection_engine import DetectionEngine

log = get_logger("m02_detection")

DEFAULT_TEMPLATES_DIR = "app/templates"


class Module(ModuleBase):
    """Detection par template matching OpenCV."""

    @property
    def name(self) -> str:
        return "Detection"

    @property
    def version(self) -> str:
        return "1.0.0"

    @property
    def description(self) -> str:
        return "Template matching OpenCV — detecte monstres, obstacles, PNJ"

    @property
    def icon(self) -> str:
        return "D"

    def initialize(self, hub, config: dict) -> None:
        self.hub = hub
        self.config = config
        self.engine = DetectionEngine()
        self._threshold = config.get("detection_threshold", 0.75)
        self._nms_overlap = config.get("nms_overlap", 0.4)
        self._templates_dir = config.get("templates_dir", DEFAULT_TEMPLATES_DIR)
        self._enabled = False
        self._last_results: list[dict] = []
        self._detection_fps = 0.0
        self._total_detections = 0
        self._frame_queue: FrameData | None = None
        self._lock = threading.Lock()
        self._running = False
        self._thread: threading.Thread | None = None

        # Charger les templates au demarrage
        count = self.engine.load_templates(self._templates_dir)
        log.info(f"Module Detection initialise — {count} templates")

    def build_ui(self, parent: int | str) -> None:
        with dpg.group(parent=parent):
            dpg.add_text("Module Detection", color=(255, 180, 50))
            dpg.add_separator()
            dpg.add_spacer(height=6)

            # === Config ===
            with dpg.group(horizontal=True):
                dpg.add_button(
                    label="Activer",
                    callback=self._on_enable,
                    tag="det_btn_enable",
                    width=120, height=32,
                )
                dpg.add_button(
                    label="Desactiver",
                    callback=self._on_disable,
                    tag="det_btn_disable",
                    width=120, height=32,
                    enabled=False,
                )
                dpg.add_spacer(width=20)
                dpg.add_button(
                    label="Recharger templates",
                    callback=self._on_reload,
                    width=160, height=32,
                )

            dpg.add_spacer(height=6)

            with dpg.group(horizontal=True):
                dpg.add_slider_float(
                    label="Seuil confiance",
                    default_value=self._threshold,
                    min_value=0.3,
                    max_value=1.0,
                    tag="det_threshold_slider",
                    width=250,
                    callback=self._on_threshold_change,
                )
                dpg.add_spacer(width=20)
                dpg.add_slider_float(
                    label="NMS overlap",
                    default_value=self._nms_overlap,
                    min_value=0.1,
                    max_value=0.9,
                    tag="det_nms_slider",
                    width=250,
                    callback=self._on_nms_change,
                )

            dpg.add_spacer(height=4)

            # === Status ===
            with dpg.group(horizontal=True):
                dpg.add_text("Status: Inactif", tag="det_status", color=(200, 200, 200))
                dpg.add_spacer(width=20)
                dpg.add_text("FPS: 0", tag="det_fps_label", color=(200, 200, 200))
                dpg.add_spacer(width=20)
                dpg.add_text(
                    f"Templates: {len(self.engine.templates)}",
                    tag="det_tpl_count",
                    color=(200, 200, 200),
                )
                dpg.add_spacer(width=20)
                dpg.add_text("Detections: 0", tag="det_count_label", color=(200, 200, 200))

            dpg.add_spacer(height=6)
            dpg.add_separator()
            dpg.add_spacer(height=4)

            # === Tableau des detections ===
            dpg.add_text("Dernieres detections:", color=(180, 180, 180))
            dpg.add_spacer(height=2)

            with dpg.table(
                tag="det_results_table",
                header_row=True,
                borders_innerH=True,
                borders_outerH=True,
                borders_innerV=True,
                borders_outerV=True,
                resizable=True,
                height=400,
            ):
                dpg.add_table_column(label="Template", width_fixed=True, init_width_or_weight=180)
                dpg.add_table_column(label="Categorie", width_fixed=True, init_width_or_weight=120)
                dpg.add_table_column(label="X", width_fixed=True, init_width_or_weight=60)
                dpg.add_table_column(label="Y", width_fixed=True, init_width_or_weight=60)
                dpg.add_table_column(label="Confiance", width_fixed=True, init_width_or_weight=80)

    # ---- Callbacks UI ----
    def _on_enable(self, sender=None, app_data=None, user_data=None):
        if self._enabled:
            return
        self._enabled = True
        self._running = True
        self._thread = threading.Thread(
            target=self._detection_loop, daemon=True, name="detection-loop"
        )
        self._thread.start()
        bus.on("frame.new", self._on_frame)
        dpg.configure_item("det_btn_enable", enabled=False)
        dpg.configure_item("det_btn_disable", enabled=True)
        dpg.set_value("det_status", "Status: Actif")
        dpg.configure_item("det_status", color=(100, 255, 100))
        log.info("Detection activee")

    def _on_disable(self, sender=None, app_data=None, user_data=None):
        self._enabled = False
        self._running = False
        bus.off("frame.new", self._on_frame)
        if self._thread and self._thread.is_alive():
            self._thread.join(timeout=2.0)
        self._thread = None
        dpg.configure_item("det_btn_enable", enabled=True)
        dpg.configure_item("det_btn_disable", enabled=False)
        dpg.set_value("det_status", "Status: Inactif")
        dpg.configure_item("det_status", color=(200, 200, 200))
        log.info("Detection desactivee")

    def _on_threshold_change(self, sender, app_data, user_data=None):
        self._threshold = app_data
        self.config["detection_threshold"] = app_data

    def _on_nms_change(self, sender, app_data, user_data=None):
        self._nms_overlap = app_data
        self.config["nms_overlap"] = app_data

    def _on_reload(self, sender=None, app_data=None, user_data=None):
        count = self.engine.load_templates(self._templates_dir)
        try:
            dpg.set_value("det_tpl_count", f"Templates: {count}")
        except Exception:
            pass
        log.info(f"Templates recharges: {count}")

    # ---- Detection loop ----
    def _on_frame(self, frame_data: FrameData) -> None:
        """Callback du bus — stocke la derniere frame pour le thread."""
        with self._lock:
            self._frame_queue = frame_data

    def _detection_loop(self):
        """Thread de detection — consomme les frames et publie les resultats."""
        fps_start = time.perf_counter()
        fps_count = 0

        while self._running:
            # Recuperer la derniere frame
            with self._lock:
                frame_data = self._frame_queue
                self._frame_queue = None

            if frame_data is None:
                time.sleep(0.02)
                continue

            # Lancer la detection
            t0 = time.perf_counter()
            raw_hits = self.engine.detect(
                frame_data.image,
                threshold=self._threshold,
                nms_overlap=self._nms_overlap,
            )
            dt = time.perf_counter() - t0

            self._last_results = raw_hits
            self._total_detections += len(raw_hits)
            fps_count += 1

            # Convertir en DetectionResult et publier
            results = []
            for hit in raw_hits:
                results.append(DetectionResult(
                    template_name=hit["template_name"],
                    x=hit["x"],
                    y=hit["y"],
                    w=hit["w"],
                    h=hit["h"],
                    confidence=hit["confidence"],
                    category=hit["category"],
                ))
            bus.emit("detection.result", results)

            # Stats FPS
            elapsed = time.perf_counter() - fps_start
            if elapsed >= 1.0:
                self._detection_fps = fps_count / elapsed
                fps_count = 0
                fps_start = time.perf_counter()
                try:
                    dpg.set_value("det_fps_label", f"FPS: {self._detection_fps:.1f}")
                    dpg.set_value("det_count_label", f"Detections: {self._total_detections}")
                    self._refresh_table(raw_hits)
                except Exception:
                    pass

    def _refresh_table(self, hits: list[dict]):
        """Met a jour le tableau des detections."""
        try:
            # Supprimer les lignes existantes
            children = dpg.get_item_children("det_results_table", 1)
            if children:
                for child in children:
                    dpg.delete_item(child)

            # Ajouter les nouvelles (max 20)
            for hit in hits[:20]:
                with dpg.table_row(parent="det_results_table"):
                    dpg.add_text(hit["template_name"])
                    dpg.add_text(hit["category"])
                    dpg.add_text(str(hit["x"]))
                    dpg.add_text(str(hit["y"]))
                    conf_color = (100, 255, 100) if hit["confidence"] > 0.85 else (255, 200, 50)
                    dpg.add_text(f"{hit['confidence']:.2f}", color=conf_color)
        except Exception as e:
            log.debug(f"Erreur refresh table: {e}")

    # ---- Lifecycle ----
    def on_show(self):
        pass

    def on_hide(self):
        pass

    def cleanup(self):
        self._on_disable()
        log.info("Module Detection nettoye")
