"""Module Sequencer v1.1.0 — layout plein espace, DearPyGui.

Occupe 100% de l'espace de l'onglet.
Split gauche/droite avec child_window autosize.
"""
from __future__ import annotations
import threading, time
from copy import deepcopy
from typing import Any, Optional

import dearpygui.dearpygui as dpg

from vision_automator_v5.module_base import ModuleBase
from vision_automator_v5.shared.bus import bus
from vision_automator_v5.shared.logger import get_logger
from vision_automator_v5.modules.m08_sequencer.sequencer_engine import SequencerEngine
from vision_automator_v5.modules.m08_sequencer.constants import (
    STEP_TYPES, STEP_LABELS, STEP_DICT, STEP_VALUE_HINTS,
    COMMON_KEYS, parse_step_type,
)

log = get_logger("m08_sequencer")

# Couleurs
C_TITLE  = (100, 200, 255)
C_GREEN  = (100, 255, 100)
C_YELLOW = (255, 230, 80)
C_ORANGE = (255, 180, 50)
C_RED    = (255, 80, 80)
C_DIM    = (150, 150, 170)
C_TEXT   = (220, 220, 220)


class Module(ModuleBase):
    @property
    def name(self) -> str: return "Sequencer"
    @property
    def version(self) -> str: return "1.1.0"
    @property
    def description(self) -> str: return "Constructeur et executeur de sequences"
    @property
    def icon(self) -> str: return "S"

    def initialize(self, hub, config: dict) -> None:
        self.hub = hub
        self.config = config
        self.engine = SequencerEngine(config)
        self._active_seq_id: Optional[int] = None
        self._exec_thread: Optional[threading.Thread] = None
        self._tpl_name_to_tid: dict[str, str] = {}
        self._ensure_seq_ids()
        log.info("Init")

    # ================================================================
    #  UI
    # ================================================================

    def build_ui(self, parent) -> None:
        # Conteneur principal qui prend tout l'espace
        with dpg.child_window(parent=parent, autosize_x=True, autosize_y=True,
                              border=False, tag="seq_root"):

            # --- Barre de controle en haut ---
            with dpg.group(horizontal=True):
                dpg.add_text("Sequencer", color=C_TITLE,
                             tag="seq_header_title")
                dpg.add_spacer(width=20)
                dpg.add_button(label="Demarrer", callback=self._start_exec,
                               tag="seq_btn_start", width=100, height=28)
                dpg.add_button(label="Arreter", callback=self._stop_exec,
                               tag="seq_btn_stop", width=100, height=28, enabled=False)
                dpg.add_button(label="Pause", callback=self._toggle_pause,
                               tag="seq_btn_pause", width=70, height=28, enabled=False)
                dpg.add_spacer(width=12)
                dpg.add_text("Arrete", tag="seq_status", color=C_DIM)

            dpg.add_spacer(height=4)
            dpg.add_separator()
            dpg.add_spacer(height=4)

            # --- Split horizontal: gauche + droite ---
            with dpg.group(horizontal=True):

                # ========== GAUCHE: arbre des sequences ==========
                with dpg.child_window(width=320, border=True, tag="seq_panel_left"):
                    dpg.add_text("Sequences", color=C_TITLE)
                    dpg.add_text("Priorite = ordre dans la liste", color=C_DIM)
                    dpg.add_spacer(height=4)

                    dpg.add_listbox(items=[], tag="seq_tree_list",
                                    num_items=18, width=-1,
                                    callback=self._on_seq_selected)

                    dpg.add_spacer(height=6)
                    with dpg.group(horizontal=True):
                        dpg.add_button(label="+ Nouveau", callback=self._add_seq,
                                       width=80, height=26)
                        dpg.add_button(label="+ Enfant", callback=self._add_child,
                                       width=70, height=26)
                        dpg.add_button(label="Renommer", callback=self._rename_seq,
                                       width=70, height=26)
                    with dpg.group(horizontal=True):
                        dpg.add_button(label="Haut", callback=self._move_seq_up,
                                       width=50, height=24)
                        dpg.add_button(label="Bas", callback=self._move_seq_down,
                                       width=50, height=24)
                        dpg.add_button(label="Copier", callback=self._copy_seq,
                                       width=55, height=24)
                        dpg.add_button(label="Supprimer", callback=self._delete_seq,
                                       width=70, height=24)
                    dpg.add_spacer(height=4)
                    dpg.add_checkbox(label="Sequence active", tag="seq_enabled_cb",
                                     default_value=True, callback=self._toggle_enabled)

                # ========== DROITE: editeur ==========
                with dpg.child_window(border=True, tag="seq_panel_right"):
                    dpg.add_text("< Selectionnez une sequence", tag="seq_name_label",
                                 color=C_TITLE)
                    dpg.add_spacer(height=6)

                    # --- Conditions ---
                    dpg.add_text("Conditions", color=C_YELLOW)
                    dpg.add_text("La sequence ne s'execute que si toutes les conditions sont remplies.",
                                 color=C_DIM)
                    dpg.add_spacer(height=2)
                    dpg.add_listbox(items=[], tag="seq_cond_list",
                                    num_items=3, width=-1)
                    dpg.add_spacer(height=2)
                    with dpg.group(horizontal=True):
                        dpg.add_text("Si", color=C_TEXT)
                        dpg.add_combo(items=[], tag="seq_cond_tpl", width=280)
                        dpg.add_combo(items=["est absent", "est present"],
                                      tag="seq_cond_mode", width=120,
                                      default_value="est absent")
                        dpg.add_button(label="+ Ajouter", callback=self._add_condition,
                                       width=70, height=24)
                        dpg.add_button(label="Suppr", callback=self._del_condition,
                                       width=50, height=24)

                    dpg.add_spacer(height=8)
                    dpg.add_separator()
                    dpg.add_spacer(height=6)

                    # --- Steps ---
                    dpg.add_text("Steps", color=C_GREEN)
                    dpg.add_listbox(items=[], tag="seq_steps_list",
                                    num_items=12, width=-1)

                    dpg.add_spacer(height=6)
                    dpg.add_separator()
                    dpg.add_spacer(height=4)

                    # --- Constructeur de step ---
                    dpg.add_text("Editeur de step", color=C_ORANGE)
                    dpg.add_spacer(height=4)

                    with dpg.group(horizontal=True):
                        dpg.add_text("Action:", color=C_TEXT)
                        dpg.add_combo(items=STEP_LABELS, tag="seq_step_type",
                                      width=280, default_value=STEP_LABELS[0],
                                      callback=self._on_step_type_changed)

                    dpg.add_spacer(height=2)
                    with dpg.group(horizontal=True):
                        dpg.add_text("Template:", color=C_TEXT)
                        dpg.add_combo(items=["(aucun)"], tag="seq_step_tpl", width=400)

                    with dpg.group(horizontal=True, tag="seq_subseq_row", show=False):
                        dpg.add_text("Sous-seq:", color=C_TEXT)
                        dpg.add_combo(items=[], tag="seq_step_subseq", width=280)

                    dpg.add_spacer(height=2)
                    with dpg.group(horizontal=True):
                        dpg.add_text("Valeur:", color=C_TEXT)
                        dpg.add_input_text(tag="seq_step_val", width=130,
                                           default_value="300")
                        dpg.add_spacer(width=8)
                        dpg.add_text("Touche:", color=C_DIM)
                        dpg.add_combo(items=COMMON_KEYS, tag="seq_key_picker",
                                      width=100, callback=self._on_key_picked)
                        dpg.add_spacer(width=8)
                        dpg.add_text("", tag="seq_val_hint", color=C_DIM)

                    dpg.add_spacer(height=6)
                    with dpg.group(horizontal=True):
                        dpg.add_button(label="+ Ajouter step", callback=self._add_step,
                                       width=100, height=28)
                        dpg.add_button(label="Editer", callback=self._edit_step,
                                       width=60, height=28)
                        dpg.add_button(label="Haut", callback=self._move_step_up,
                                       width=50, height=28)
                        dpg.add_button(label="Bas", callback=self._move_step_down,
                                       width=50, height=28)
                        dpg.add_button(label="Copier", callback=self._copy_step,
                                       width=55, height=28)
                        dpg.add_button(label="Suppr", callback=self._del_step,
                                       width=55, height=28)

            # --- Log en bas ---
            dpg.add_spacer(height=4)
            dpg.add_separator()
            dpg.add_spacer(height=2)
            dpg.add_text("Log Sequencer", color=C_DIM)
            dpg.add_input_text(tag="seq_log", multiline=True, readonly=True,
                               width=-1, height=100, default_value="")

        self._refresh_all()

    # ================================================================
    #  Refresh
    # ================================================================

    def _refresh_all(self) -> None:
        self._ensure_seq_ids()
        self._refresh_tree()
        self._refresh_template_combos()

    def _refresh_tree(self) -> None:
        items = []
        def walk(seqs, depth=0):
            for s in seqs:
                prefix = "  " * depth
                icon = "[+]" if s.get("enabled", True) else "[-]"
                ns = len(s.get("steps", []))
                nc = len(s.get("conditions", []))
                nch = len(s.get("children", []))
                label = f"{prefix}{icon} {s['name']} ({ns} steps"
                if nc: label += f", {nc} cond"
                if nch: label += f", {nch} enfants"
                label += ")"
                items.append(label)
                walk(s.get("children", []), depth + 1)
        walk(self.config.get("sequences", []))
        try:
            dpg.configure_item("seq_tree_list", items=items)
        except: pass

        sub_items = []
        def walk_sub(seqs, prefix=""):
            for s in seqs:
                sub_items.append(f"[{s['id']}] {prefix}{s['name']}")
                walk_sub(s.get("children", []), prefix + "  ")
        walk_sub(self.config.get("sequences", []))
        try:
            dpg.configure_item("seq_step_subseq", items=sub_items)
        except: pass

    def _refresh_template_combos(self) -> None:
        names = []
        self._tpl_name_to_tid.clear()
        for tid, meta in self.config.get("templates", {}).items():
            nv = meta.get("variant_count", 1)
            display = f"{meta.get('name','?')}  |  {meta.get('category','')}  ({nv}v)"
            names.append(display)
            self._tpl_name_to_tid[display] = tid
        names.sort()
        all_vals = ["(aucun)"] + names
        try:
            dpg.configure_item("seq_step_tpl", items=all_vals)
            dpg.configure_item("seq_cond_tpl", items=all_vals)
        except: pass

    def _refresh_steps(self) -> None:
        seq = self._get_active_seq()
        if not seq:
            try: dpg.configure_item("seq_steps_list", items=[])
            except: pass
            return
        items = []
        for i, step in enumerate(seq.get("steps", [])):
            stype = step.get("type", "?")
            label = STEP_DICT.get(stype, stype)
            tpl = step.get("template", "")
            tpl_name = ""
            if tpl:
                meta = self.config.get("templates", {}).get(tpl, {})
                tpl_name = f" -> {meta.get('name', '?')}"
            val = step.get("value", "")
            val_str = f" ({val})" if val else ""
            sub_info = ""
            if stype in ("sous_sequence", "si_detecte_alors", "si_absent_alors"):
                sub_id = step.get("sub_sequence_id")
                if sub_id:
                    sub = self._find_seq_by_id(sub_id)
                    sub_info = f" => [{sub['name']}]" if sub else f" => [?{sub_id}]"
            items.append(f"  {i+1}. {label}{tpl_name}{sub_info}{val_str}")
        try:
            dpg.configure_item("seq_steps_list", items=items)
        except: pass

    def _refresh_conditions(self) -> None:
        seq = self._get_active_seq()
        if not seq:
            try: dpg.configure_item("seq_cond_list", items=[])
            except: pass
            return
        items = []
        for i, cond in enumerate(seq.get("conditions", [])):
            tpl = cond.get("template", "")
            meta = self.config.get("templates", {}).get(tpl, {})
            name = meta.get("name", "?")
            cat = meta.get("category", "")
            mode = "ABSENT" if cond.get("mode") == "absent" else "PRESENT"
            items.append(f"  {i+1}. {name} [{cat}] est {mode}")
        try:
            dpg.configure_item("seq_cond_list", items=items)
        except: pass

    # ================================================================
    #  Helpers sequences
    # ================================================================

    def _ensure_seq_ids(self) -> None:
        counter = [1000]
        def walk(seqs):
            for s in seqs:
                if "id" not in s:
                    counter[0] += 1
                    s["id"] = counter[0]
                s.setdefault("children", [])
                s.setdefault("conditions", [])
                s.setdefault("steps", [])
                walk(s["children"])
        walk(self.config.get("sequences", []))

    def _next_seq_id(self) -> int:
        max_id = [0]
        def walk(seqs):
            for s in seqs:
                if s.get("id", 0) > max_id[0]:
                    max_id[0] = s["id"]
                walk(s.get("children", []))
        walk(self.config.get("sequences", []))
        return max_id[0] + 1

    def _get_flat_list(self) -> list[dict]:
        result = []
        def walk(seqs):
            for s in seqs:
                result.append(s)
                walk(s.get("children", []))
        walk(self.config.get("sequences", []))
        return result

    def _get_active_seq(self) -> Optional[dict]:
        if self._active_seq_id is None:
            return None
        return self._find_seq_by_id(self._active_seq_id)

    def _find_seq_by_id(self, sid: int, seqs: list = None) -> Optional[dict]:
        if seqs is None:
            seqs = self.config.get("sequences", [])
        for s in seqs:
            if s.get("id") == sid:
                return s
            found = self._find_seq_by_id(sid, s.get("children", []))
            if found:
                return found
        return None

    def _get_parent_list(self, sid: int, seqs: list = None):
        if seqs is None:
            seqs = self.config.get("sequences", [])
        for i, s in enumerate(seqs):
            if s.get("id") == sid:
                return seqs, i
            r = self._get_parent_list(sid, s.get("children", []))
            if r:
                return r
        return None

    def _save(self) -> None:
        if self.hub:
            self.hub.save_config()

    def _seq_log(self, msg: str, level: str = "info") -> None:
        try:
            current = dpg.get_value("seq_log") or ""
            ts = time.strftime("%H:%M:%S")
            prefix = {"info": " ", "ok": "+", "warn": "!", "error": "X"}.get(level, " ")
            new_line = f"[{ts}] {prefix} {msg}\n"
            # Garder max 50 lignes
            lines = (current + new_line).split("\n")
            if len(lines) > 50:
                lines = lines[-50:]
            dpg.set_value("seq_log", "\n".join(lines))
        except: pass

    # ================================================================
    #  Callbacks — arbre
    # ================================================================

    def _on_seq_selected(self, sender, app_data, user_data=None) -> None:
        flat = self._get_flat_list()
        items = dpg.get_item_configuration("seq_tree_list").get("items", [])
        if app_data in items:
            idx = items.index(app_data)
            if 0 <= idx < len(flat):
                seq = flat[idx]
                self._active_seq_id = seq["id"]
                try:
                    dpg.set_value("seq_name_label", f"> {seq['name']}")
                    dpg.set_value("seq_enabled_cb", seq.get("enabled", True))
                except: pass
                self._refresh_steps()
                self._refresh_conditions()

    def _add_seq(self, s=None, a=None, u=None) -> None:
        sid = self._next_seq_id()
        name = f"Sequence {sid}"
        seq = {"id": sid, "name": name, "enabled": True,
               "steps": [], "children": [], "conditions": []}
        self.config.setdefault("sequences", []).append(seq)
        self._active_seq_id = seq["id"]
        self._save()
        self._refresh_all()
        self._seq_log(f"Creee: {name}", "ok")

    def _add_child(self, s=None, a=None, u=None) -> None:
        parent = self._get_active_seq()
        if not parent:
            self._seq_log("Selectionnez un parent", "warn")
            return
        sid = self._next_seq_id()
        child = {"id": sid, "name": f"Enfant {sid}", "enabled": True,
                 "steps": [], "children": [], "conditions": []}
        parent.setdefault("children", []).append(child)
        self._active_seq_id = child["id"]
        self._save()
        self._refresh_all()

    def _rename_seq(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        def _do(sender, app_data, user_data):
            val = dpg.get_value("seq_rename_input")
            if val and val.strip():
                seq["name"] = val.strip()
                self._save()
                self._refresh_all()
                try: dpg.set_value("seq_name_label", f"> {seq['name']}")
                except: pass
            if dpg.does_item_exist("seq_rename_win"):
                dpg.delete_item("seq_rename_win")
        if dpg.does_item_exist("seq_rename_win"):
            dpg.delete_item("seq_rename_win")
        with dpg.window(label="Renommer", tag="seq_rename_win",
                        width=400, height=90, modal=True, no_resize=True,
                        pos=[400, 300]):
            dpg.add_input_text(tag="seq_rename_input", default_value=seq["name"],
                               width=-1, on_enter=True, callback=_do)
            dpg.add_spacer(height=4)
            with dpg.group(horizontal=True):
                dpg.add_button(label="OK", callback=_do, width=80, height=26)
                dpg.add_button(label="Annuler", width=80, height=26,
                               callback=lambda: dpg.delete_item("seq_rename_win"))

    def _delete_seq(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        r = self._get_parent_list(seq["id"])
        if r:
            lst, idx = r
            lst.pop(idx)
        self._active_seq_id = None
        self._save()
        self._refresh_all()
        try:
            dpg.configure_item("seq_steps_list", items=[])
            dpg.configure_item("seq_cond_list", items=[])
            dpg.set_value("seq_name_label", "< Selectionnez une sequence")
        except: pass
        self._seq_log("Sequence supprimee", "info")

    def _toggle_enabled(self, sender=None, app_data=None, user_data=None) -> None:
        seq = self._get_active_seq()
        if seq:
            seq["enabled"] = dpg.get_value("seq_enabled_cb")
            self._save()
            self._refresh_tree()

    def _move_seq_up(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        r = self._get_parent_list(seq["id"])
        if r:
            lst, idx = r
            if idx > 0:
                lst[idx], lst[idx-1] = lst[idx-1], lst[idx]
                self._save(); self._refresh_tree()

    def _move_seq_down(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        r = self._get_parent_list(seq["id"])
        if r:
            lst, idx = r
            if idx < len(lst) - 1:
                lst[idx], lst[idx+1] = lst[idx+1], lst[idx]
                self._save(); self._refresh_tree()

    def _copy_seq(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        cp = deepcopy(seq)
        def reid(s):
            s["id"] = self._next_seq_id()
            s["name"] += " (copie)"
            for ch in s.get("children", []): reid(ch)
        reid(cp)
        r = self._get_parent_list(seq["id"])
        if r:
            lst, idx = r
            lst.insert(idx + 1, cp)
        else:
            self.config.setdefault("sequences", []).append(cp)
        self._active_seq_id = cp["id"]
        self._save(); self._refresh_all()

    # ================================================================
    #  Callbacks — conditions
    # ================================================================

    def _add_condition(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq:
            self._seq_log("Selectionnez une sequence", "warn"); return
        tpl_display = dpg.get_value("seq_cond_tpl")
        if not tpl_display or tpl_display == "(aucun)":
            self._seq_log("Selectionnez un template", "warn"); return
        tpl_tid = self._tpl_name_to_tid.get(tpl_display, "")
        if not tpl_tid: return
        mode = "absent" if "absent" in dpg.get_value("seq_cond_mode") else "present"
        seq.setdefault("conditions", []).append({"template": tpl_tid, "mode": mode})
        self._save(); self._refresh_conditions()
        self._refresh_tree()

    def _del_condition(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        sel = dpg.get_value("seq_cond_list")
        if not sel: return
        items = dpg.get_item_configuration("seq_cond_list").get("items", [])
        if sel in items:
            idx = items.index(sel)
            conds = seq.get("conditions", [])
            if 0 <= idx < len(conds):
                conds.pop(idx)
                self._save(); self._refresh_conditions()
                self._refresh_tree()

    # ================================================================
    #  Callbacks — steps
    # ================================================================

    def _on_step_type_changed(self, sender=None, app_data=None, user_data=None) -> None:
        stype = parse_step_type(dpg.get_value("seq_step_type"))
        show_sub = stype in ("sous_sequence", "si_detecte_alors", "si_absent_alors")
        try: dpg.configure_item("seq_subseq_row", show=show_sub)
        except: pass
        try: dpg.set_value("seq_val_hint", STEP_VALUE_HINTS.get(stype, ""))
        except: pass

    def _on_key_picked(self, sender=None, app_data=None, user_data=None) -> None:
        key = dpg.get_value("seq_key_picker")
        if key:
            try: dpg.set_value("seq_step_val", key)
            except: pass

    def _build_step(self) -> dict[str, Any]:
        stype = parse_step_type(dpg.get_value("seq_step_type"))
        tpl_display = dpg.get_value("seq_step_tpl")
        tpl_tid = ""
        if tpl_display and tpl_display != "(aucun)":
            tpl_tid = self._tpl_name_to_tid.get(tpl_display, "")
        val = dpg.get_value("seq_step_val").strip()
        step: dict[str, Any] = {"type": stype, "template": tpl_tid, "value": val}
        if stype in ("sous_sequence", "si_detecte_alors", "si_absent_alors"):
            sub_str = dpg.get_value("seq_step_subseq")
            if sub_str:
                try:
                    step["sub_sequence_id"] = int(sub_str.split("]")[0].replace("[", ""))
                except ValueError:
                    pass
        return step

    def _sel_step_idx(self) -> int:
        sel = dpg.get_value("seq_steps_list")
        if not sel: return -1
        items = dpg.get_item_configuration("seq_steps_list").get("items", [])
        return items.index(sel) if sel in items else -1

    def _add_step(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq:
            self._seq_log("Selectionnez une sequence", "warn"); return
        seq.setdefault("steps", []).append(self._build_step())
        self._save(); self._refresh_steps(); self._refresh_tree()

    def _edit_step(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        idx = self._sel_step_idx()
        if idx < 0: return
        seq["steps"][idx] = self._build_step()
        self._save(); self._refresh_steps(); self._refresh_tree()

    def _del_step(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        idx = self._sel_step_idx()
        if idx < 0: return
        seq["steps"].pop(idx)
        self._save(); self._refresh_steps(); self._refresh_tree()

    def _move_step_up(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        i = self._sel_step_idx()
        if i <= 0: return
        seq["steps"][i], seq["steps"][i-1] = seq["steps"][i-1], seq["steps"][i]
        self._save(); self._refresh_steps()

    def _move_step_down(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        i = self._sel_step_idx()
        if i < 0 or i >= len(seq["steps"]) - 1: return
        seq["steps"][i], seq["steps"][i+1] = seq["steps"][i+1], seq["steps"][i]
        self._save(); self._refresh_steps()

    def _copy_step(self, s=None, a=None, u=None) -> None:
        seq = self._get_active_seq()
        if not seq: return
        i = self._sel_step_idx()
        if i < 0: return
        seq["steps"].insert(i + 1, deepcopy(seq["steps"][i]))
        self._save(); self._refresh_steps()

    # ================================================================
    #  Execution
    # ================================================================

    def _start_exec(self, s=None, a=None, u=None) -> None:
        if self.engine.running: return
        self.engine.running = True
        self.engine.paused = False
        self.engine.set_log_callback(self._seq_log)
        bus.on("detection.result", self.engine.on_detection_result)
        bus.on("frame.new", self.engine.on_frame)
        self._exec_thread = threading.Thread(target=self._exec_loop,
                                             daemon=True, name="sequencer")
        self._exec_thread.start()
        try:
            dpg.configure_item("seq_btn_start", enabled=False)
            dpg.configure_item("seq_btn_stop", enabled=True)
            dpg.configure_item("seq_btn_pause", enabled=True)
            dpg.set_value("seq_status", "En cours")
            dpg.configure_item("seq_status", color=C_GREEN)
        except: pass
        self._seq_log("Sequencer demarre", "ok")
        bus.emit("sequencer.state_changed", "running")

    def _stop_exec(self, s=None, a=None, u=None) -> None:
        self.engine.running = False
        self.engine.paused = False
        try:
            bus.off("detection.result", self.engine.on_detection_result)
            bus.off("frame.new", self.engine.on_frame)
        except: pass
        if self._exec_thread and self._exec_thread.is_alive():
            self._exec_thread.join(timeout=3.0)
        self._exec_thread = None
        try:
            dpg.configure_item("seq_btn_start", enabled=True)
            dpg.configure_item("seq_btn_stop", enabled=False)
            dpg.configure_item("seq_btn_pause", enabled=False)
            dpg.set_value("seq_status", "Arrete")
            dpg.configure_item("seq_status", color=C_DIM)
        except: pass
        self._seq_log("Sequencer arrete", "info")
        bus.emit("sequencer.state_changed", "stopped")

    def _toggle_pause(self, s=None, a=None, u=None) -> None:
        self.engine.paused = not self.engine.paused
        if self.engine.paused:
            try:
                dpg.set_value("seq_status", "En pause")
                dpg.configure_item("seq_status", color=C_YELLOW)
            except: pass
        else:
            try:
                dpg.set_value("seq_status", "En cours")
                dpg.configure_item("seq_status", color=C_GREEN)
            except: pass
        bus.emit("sequencer.state_changed", "paused" if self.engine.paused else "running")

    def _exec_loop(self) -> None:
        interval = self.config.get("scan_interval_ms", 500) / 1000.0
        while self.engine.running:
            if not self.engine.paused:
                try:
                    self.engine.execute_all()
                except Exception as e:
                    self._seq_log(f"Erreur: {e}", "error")
            time.sleep(max(0.1, interval))

    # ================================================================
    #  Lifecycle
    # ================================================================

    def on_show(self) -> None:
        self._refresh_all()

    def on_hide(self) -> None:
        pass

    def cleanup(self) -> None:
        self._stop_exec()
        log.info("Done")
