"""Hub — Fenetre principale modulaire.

NE PAS MODIFIER une fois verrouille.
Version: 1.0.0

Le Hub:
- Cree la fenetre DearPyGui
- Decouvre et charge les modules
- Affiche une sidebar avec les modules disponibles
- Gere le cycle de vie (init, show, hide, cleanup)
"""
from __future__ import annotations
import json
from pathlib import Path
import dearpygui.dearpygui as dpg
from vision_automator_v5.module_base import ModuleBase
from vision_automator_v5.module_registry import discover_modules
from vision_automator_v5.shared.logger import get_logger
from vision_automator_v5.shared.bus import bus
from vision_automator_v5.shared import constants as C

log = get_logger("hub")

CONFIG_PATH = Path(__file__).parent.parent / "app" / "config.json"


class Hub:
    """Fenetre principale — charge et affiche les modules."""

    def __init__(self):
        self.config: dict = self._load_config()
        self.modules: list[ModuleBase] = []
        self._active_module: ModuleBase | None = None
        self._module_containers: dict[str, int] = {}
        self._sidebar_buttons: dict[str, int] = {}

    # ---- Config ----
    def _load_config(self) -> dict:
        if CONFIG_PATH.exists():
            try:
                return json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
            except Exception as e:
                log.error(f"Erreur lecture config: {e}")
        return {}

    def save_config(self) -> None:
        CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
        CONFIG_PATH.write_text(
            json.dumps(self.config, indent=2, ensure_ascii=False),
            encoding="utf-8"
        )
        log.info("Config sauvegardee")

    # ---- Modules ----
    def _load_modules(self) -> None:
        classes = discover_modules()
        for cls in classes:
            try:
                instance = cls()
                instance.initialize(self, self.config)
                self.modules.append(instance)
                log.info(f"Module charge: {instance.name} v{instance.version}")
            except Exception as e:
                log.error(f"Erreur init module {cls}: {e}")

    def _switch_module(self, module: ModuleBase) -> None:
        # Masquer le module actif
        if self._active_module:
            self._active_module.on_hide()
            tag = self._module_containers.get(self._active_module.name)
            if tag:
                dpg.configure_item(tag, show=False)

        # Afficher le nouveau
        self._active_module = module
        tag = self._module_containers.get(module.name)
        if tag:
            dpg.configure_item(tag, show=True)
        module.on_show()

        # Mettre a jour la sidebar (highlight)
        for name, btn_id in self._sidebar_buttons.items():
            if name == module.name:
                dpg.bind_item_theme(btn_id, self._theme_active_btn)
            else:
                dpg.bind_item_theme(btn_id, self._theme_normal_btn)

        log.info(f"Module actif: {module.name}")

    # ---- UI ----
    def _build_ui(self) -> None:
        # Themes pour la sidebar
        with dpg.theme() as self._theme_normal_btn:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_color(dpg.mvThemeCol_Button, (40, 40, 45, 255))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered, (60, 60, 70, 255))
                dpg.add_theme_color(dpg.mvThemeCol_Text, (180, 180, 180, 255))
                dpg.add_theme_style(dpg.mvStyleVar_FrameRounding, 6)

        with dpg.theme() as self._theme_active_btn:
            with dpg.theme_component(dpg.mvButton):
                dpg.add_theme_color(dpg.mvThemeCol_Button, (50, 100, 200, 255))
                dpg.add_theme_color(dpg.mvThemeCol_ButtonHovered, (60, 120, 220, 255))
                dpg.add_theme_color(dpg.mvThemeCol_Text, (255, 255, 255, 255))
                dpg.add_theme_style(dpg.mvStyleVar_FrameRounding, 6)

        # Theme global
        with dpg.theme() as global_theme:
            with dpg.theme_component(dpg.mvAll):
                dpg.add_theme_color(dpg.mvThemeCol_WindowBg, (25, 25, 30, 255))
                dpg.add_theme_color(dpg.mvThemeCol_TitleBg, (30, 30, 40, 255))
                dpg.add_theme_color(dpg.mvThemeCol_TitleBgActive, (40, 60, 120, 255))
                dpg.add_theme_style(dpg.mvStyleVar_WindowRounding, 4)
                dpg.add_theme_style(dpg.mvStyleVar_FrameRounding, 4)
        dpg.bind_theme(global_theme)

        # Fenetre principale (plein ecran dans le viewport)
        with dpg.window(tag="main_window"):
            with dpg.group(horizontal=True):
                # === SIDEBAR ===
                with dpg.child_window(width=200, tag="sidebar"):
                    dpg.add_text(f"{C.APP_NAME} v{C.APP_VERSION}")
                    dpg.add_separator()
                    dpg.add_spacer(height=8)

                    if not self.modules:
                        dpg.add_text("Aucun module charge", color=(150, 150, 150))
                    else:
                        for mod in self.modules:
                            btn_label = f" {mod.icon}  {mod.name}"
                            btn = dpg.add_button(
                                label=btn_label,
                                width=-1,
                                height=36,
                                callback=lambda s, a, u: self._switch_module(u),
                                user_data=mod,
                            )
                            dpg.bind_item_theme(btn, self._theme_normal_btn)
                            self._sidebar_buttons[mod.name] = btn

                    dpg.add_spacer(height=20)
                    dpg.add_separator()
                    dpg.add_spacer(height=4)
                    dpg.add_text(f"Modules: {len(self.modules)}", color=(120, 120, 130))
                    bus_events = bus.list_events()
                    dpg.add_text(f"Bus events: {len(bus_events)}", color=(120, 120, 130))

                # === ZONE CONTENU ===
                with dpg.child_window(tag="content_area"):
                    if not self.modules:
                        dpg.add_text(
                            "Aucun module detecte.\n\n"
                            "Les modules se placent dans:\n"
                            "  vision_automator_v5/modules/m01_xxx/module.py\n\n"
                            "Chaque module doit exporter une classe 'Module'\n"
                            "qui herite de ModuleBase.",
                            color=(150, 150, 150),
                        )
                    else:
                        # Creer un conteneur par module
                        for mod in self.modules:
                            with dpg.group(tag=f"module_container_{mod.name}", show=False) as container:
                                self._module_containers[mod.name] = container
                                try:
                                    mod.build_ui(container)
                                except Exception as e:
                                    dpg.add_text(
                                        f"Erreur build_ui pour {mod.name}: {e}",
                                        color=(255, 80, 80),
                                    )
                                    log.error(f"build_ui {mod.name}: {e}")

        dpg.set_primary_window("main_window", True)

        # Activer le premier module
        if self.modules:
            self._switch_module(self.modules[0])

    # ---- Lifecycle ----
    def _cleanup(self) -> None:
        log.info("Arret en cours...")
        for mod in self.modules:
            try:
                mod.cleanup()
            except Exception as e:
                log.error(f"cleanup {mod.name}: {e}")
        self.save_config()
        bus.clear()
        log.info("Arret propre termine")

    def run(self) -> None:
        """Point d'entree principal."""
        dpg.create_context()
        dpg.create_viewport(
            title=f"{C.APP_NAME} v{C.APP_VERSION}",
            width=1400,
            height=900,
            min_width=800,
            min_height=600,
        )

        self._load_modules()
        self._build_ui()

        dpg.setup_dearpygui()
        dpg.show_viewport()

        log.info(f"{C.APP_NAME} v{C.APP_VERSION} demarre — {len(self.modules)} module(s)")

        # Render loop
        while dpg.is_dearpygui_running():
            dpg.render_dearpygui_frame()

        # Cleanup
        self._cleanup()
        dpg.destroy_context()
