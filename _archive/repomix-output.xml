"""Module Capture v3.1.0 — WGC capture, anti-flicker.

- WGC capture
- Double-buffer anti-flicker (plus de flash noir)
- Preview: BGRA->RGB resize + float32
- Bus: BGRA->BGR une seule fois
"""
from __future__ import annotations
import threading, time
import cv2, numpy as np
import dearpygui.dearpygui as dpg

from vision_automator_v5.module_base import ModuleBase
from vision_automator_v5.shared.bus import bus
from vision_automator_v5.shared.logger import get_logger
from vision_automator_v5.shared.types import FrameData
from vision_automator_v5.modules.m01_capture.capture_engine import CaptureEngine

log = get_logger("m01_capture")

PW = 1280
PH = 720


class Module(ModuleBase):
    @property
    def name(self): return "Capture"
    @property
    def version(self): return "3.1.0"
    @property
    def description(self): return "WGC capture anti-flicker"
    @property
    def icon(self): return "C"

    def initialize(self, hub, config):
        self.hub = hub
        self.config = config
        self.engine = CaptureEngine()
        self._on = False
        self._thread = None
        self._fc = 0
        self._wl = []
        self._sel = ""
        # Double buffer: on ecrit dans _write_buf, on affiche _read_buf
        # Pas de flash noir: _read_buf garde la derniere frame valide
        self._buf_a = np.zeros(PH * PW * 4, dtype=np.float32)
        self._buf_b = np.zeros(PH * PW * 4, dtype=np.float32)
        self._write_buf = self._buf_a
        self._read_buf = self._buf_b
        self._write_4d = self._write_buf.reshape(PH, PW, 4)
        self._read_4d = self._read_buf.reshape(PH, PW, 4)
        # Init alpha a 1.0 sur les deux
        self._write_4d[:, :, 3] = 1.0
        self._read_4d[:, :, 3] = 1.0
        self._has_first_frame = False
        log.info("Init")

    def build_ui(self, parent):
        with dpg.group(parent=parent):
            dpg.add_text("Capture v3.1", color=(100, 200, 255))
            dpg.add_separator()
            dpg.add_spacer(height=4)
            with dpg.group(horizontal=True):
                dpg.add_button(label="Rafraichir", callback=self._ref_win, width=100, height=28)
                dpg.add_combo(items=[], label="", tag="cap_combo", width=700, callback=self._sel_win)
            dpg.add_spacer(height=4)
            with dpg.group(horizontal=True):
                dpg.add_button(label="Demarrer", callback=self._go, tag="cap_go", width=110, height=30)
                dpg.add_button(label="Arreter", callback=self._stop_ui, tag="cap_stop", width=110, height=30, enabled=False)
            dpg.add_spacer(height=2)
            with dpg.group(horizontal=True):
                dpg.add_text("Stop", tag="cap_st", color=(200,200,200))
                dpg.add_spacer(width=12)
                dpg.add_text("WGC: 0", tag="cap_wfps", color=(200,200,200))
                dpg.add_spacer(width=12)
                dpg.add_text("Bus: 0", tag="cap_bfps", color=(200,200,200))
                dpg.add_spacer(width=12)
                dpg.add_text("#0", tag="cap_fc", color=(200,200,200))
                dpg.add_spacer(width=12)
                dpg.add_text("-", tag="cap_res", color=(200,200,200))
            dpg.add_spacer(height=4)
            dpg.add_separator()
            # Texture: pointe vers _read_buf (toujours la derniere frame valide)
            with dpg.texture_registry(show=False):
                dpg.add_raw_texture(width=PW, height=PH, default_value=self._read_buf,
                    format=dpg.mvFormat_Float_rgba, tag="cap_tex")
            dpg.add_image("cap_tex", width=PW, height=PH)
        self._ref_win()

    def _ref_win(self, s=None, a=None, u=None):
        self._wl = self.engine.list_windows()
        items = [f"[{h}] {t}" for h, t in self._wl]
        dpg.configure_item("cap_combo", items=items)
        d = self.config.get("window_title", "")
        for i, (h, t) in enumerate(self._wl):
            if d and d.lower() in t.lower():
                dpg.set_value("cap_combo", items[i])
                self._sel = t
                break
        else:
            if items:
                dpg.set_value("cap_combo", items[0])
                self._sel = self._wl[0][1]

    def _sel_win(self, s, a, u=None):
        for h, t in self._wl:
            if f"[{h}] {t}" == a:
                self._sel = t
                break

    def _go(self, s=None, a=None, u=None):
        if self.engine.running or not self._sel: return
        ok = self.engine.start(self._sel)
        if not ok:
            dpg.set_value("cap_st", "ECHEC")
            dpg.configure_item("cap_st", color=(255,80,80))
            return
        self._on = True
        self._fc = 0
        self._has_first_frame = False
        self._thread = threading.Thread(target=self._loop, daemon=True, name="emitter")
        self._thread.start()
        dpg.configure_item("cap_go", enabled=False)
        dpg.configure_item("cap_stop", enabled=True)
        dpg.set_value("cap_st", self._sel[:40])
        dpg.configure_item("cap_st", color=(100,255,100))
        dpg.set_value("cap_res", f"{self.engine.width}x{self.engine.height}")
        bus.emit("capture.started")

    def _stop_ui(self, s=None, a=None, u=None):
        self._on = False
        self.engine.stop()
        if self._thread and self._thread.is_alive():
            self._thread.join(timeout=2.0)
        self._thread = None
        try:
            dpg.configure_item("cap_go", enabled=True)
            dpg.configure_item("cap_stop", enabled=False)
            dpg.set_value("cap_st", "Stop")
            dpg.configure_item("cap_st", color=(200,200,200))
        except: pass
        bus.emit("capture.stopped")

    def _swap_buffers(self):
        """Echange les buffers: le write devient le read, et vice versa.
        La texture DPG pointe toujours vers _read_buf, qui contient
        maintenant la frame fraiche. L'ancien read (ancienne frame)
        devient le nouveau write target."""
        self._write_buf, self._read_buf = self._read_buf, self._write_buf
        self._write_4d = self._write_buf.reshape(PH, PW, 4)
        self._read_4d = self._read_buf.reshape(PH, PW, 4)
        # Mettre a jour la texture pour pointer vers le nouveau read_buf
        dpg.set_value("cap_tex", self._read_buf)

    def _loop(self):
        lid = 0
        bc = 0
        bt = time.perf_counter()

        while self._on and self.engine.running:
            bgra, fid, fw, fh = self.engine.get_frame()
            if bgra is None or fid == lid:
                time.sleep(0.001)
                continue

            lid = fid
            self._fc += 1
            bc += 1

            # BGR pour le bus
            bgr = cv2.cvtColor(bgra, cv2.COLOR_BGRA2BGR)
            bus.emit("frame.new", FrameData(
                image=bgr, timestamp=time.perf_counter(),
                frame_id=self._fc, width=fw, height=fh,
            ))

            # Preview toutes les 2 frames — ecrit dans write_buf puis swap
            if self._fc % 2 == 0 or not self._has_first_frame:
                try:
                    scale = min(PW / fw, PH / fh)
                    nw, nh = int(fw * scale), int(fh * scale)
                    small = cv2.resize(bgra, (nw, nh), interpolation=cv2.INTER_NEAREST)
                    rgb = cv2.cvtColor(small, cv2.COLOR_BGRA2RGB)
                    # Clear write buffer (noir)
                    self._write_4d[:, :, :3] = 0.0
                    # Copier la frame centree
                    oy = (PH - nh) // 2
                    ox = (PW - nw) // 2
                    self._write_4d[oy:oy+nh, ox:ox+nw, :3] = rgb.astype(np.float32) * (1.0/255.0)
                    # Swap: la texture affiche maintenant cette frame
                    self._swap_buffers()
                    self._has_first_frame = True
                except Exception:
                    pass

            # Stats
            now = time.perf_counter()
            el = now - bt
            if el >= 1.0:
                bfps = bc / el
                bc = 0
                bt = now
                try:
                    dpg.set_value("cap_wfps", f"WGC: {self.engine.fps:.0f}")
                    dpg.set_value("cap_bfps", f"Bus: {bfps:.0f}")
                    dpg.set_value("cap_fc", f"#{self._fc}")
                except: pass

    def on_show(self): pass
    def on_hide(self): pass
    def cleanup(self):
        self._stop_ui()
        log.info("Done")
