"""Moteur d'execution des sequences.

Porte depuis vision_automator/core/sequencer.py (V4).
Adapte pour l'architecture V5 (bus events).

Ecoute: detection.result, frame.new
Emet:   sequencer.step_executed, sequencer.sequence_done,
        sequencer.log, sequencer.state_changed
"""
from __future__ import annotations
import time, sys, threading
from typing import Any, Optional, Callable
import numpy as np

from vision_automator_v5.shared.logger import get_logger
from vision_automator_v5.shared.bus import bus
from vision_automator_v5.modules.m08_sequencer.constants import SLOT_KEYS_AZERTY

log = get_logger("sequencer_engine")

IS_WINDOWS = sys.platform == "win32"

if IS_WINDOWS:
    import win32api, win32con, win32gui

try:
    import keyboard as kb_module
    HAS_KEYBOARD = True
except ImportError:
    kb_module = None
    HAS_KEYBOARD = False


def _set_cursor(x: int, y: int) -> None:
    if IS_WINDOWS:
        win32api.SetCursorPos((x, y))

def _mouse_click(x: int, y: int, button: str = "left") -> None:
    if not IS_WINDOWS:
        return
    _set_cursor(x, y)
    time.sleep(0.05)
    if button == "left":
        win32api.mouse_event(win32con.MOUSEEVENTF_LEFTDOWN, x, y, 0, 0)
        time.sleep(0.02)
        win32api.mouse_event(win32con.MOUSEEVENTF_LEFTUP, x, y, 0, 0)
    else:
        win32api.mouse_event(win32con.MOUSEEVENTF_RIGHTDOWN, x, y, 0, 0)
        time.sleep(0.02)
        win32api.mouse_event(win32con.MOUSEEVENTF_RIGHTUP, x, y, 0, 0)


class SequencerEngine:
    """Execute les sequences d'automatisation."""

    def __init__(self, config: dict[str, Any]):
        self.config = config
        self.running = False
        self.paused = False
        self._lock = threading.Lock()
        self._last_det_map: dict[str, list] = {}
        self._last_frame: Optional[np.ndarray] = None
        self._last_frame_w = 0
        self._last_frame_h = 0
        self._log_cb: Optional[Callable[[str, str], None]] = None

    def set_log_callback(self, cb: Callable[[str, str], None]) -> None:
        self._log_cb = cb

    def _log(self, msg: str, level: str = "info") -> None:
        log.info(msg) if level == "info" else log.warning(msg) if level == "warn" else log.error(msg)
        if self._log_cb:
            try:
                self._log_cb(msg, level)
            except Exception:
                pass
        bus.emit("sequencer.log", msg, level)

    def on_detection_result(self, results: list) -> None:
        """Callback bus: met a jour le cache des detections."""
        det_map: dict[str, list] = {}
        for r in results:
            key = r.template_name if hasattr(r, "template_name") else str(r)
            if key not in det_map:
                det_map[key] = []
            if hasattr(r, "x"):
                det_map[key].append((r.x, r.y, r.w, r.h, r.confidence))
        with self._lock:
            self._last_det_map = det_map

    def on_frame(self, frame_data) -> None:
        """Callback bus: met a jour la derniere frame."""
        with self._lock:
            self._last_frame = frame_data.image
            self._last_frame_w = frame_data.width
            self._last_frame_h = frame_data.height

    def get_det_map(self) -> dict[str, list]:
        with self._lock:
            return dict(self._last_det_map)

    def get_screen_offset(self) -> tuple[int, int]:
        """Recupere la position ecran de la fenetre cible."""
        if not IS_WINDOWS:
            return (0, 0)
        title = self.config.get("window_title", "")
        if not title:
            return (0, 0)
        try:
            import win32gui
            def find_hwnd(hwnd, _):
                if win32gui.IsWindowVisible(hwnd):
                    t = win32gui.GetWindowText(hwnd)
                    if title.lower() in t.lower():
                        find_hwnd.result = hwnd
            find_hwnd.result = 0
            win32gui.EnumWindows(find_hwnd, None)
            hwnd = find_hwnd.result
            if hwnd:
                return win32gui.ClientToScreen(hwnd, (0, 0))
        except Exception:
            pass
        return (0, 0)

    def execute_all(self) -> None:
        """Execute toutes les sequences actives (appel unique par tick)."""
        if not self.running or self.paused:
            return
        det_map = self.get_det_map()
        scr_x, scr_y = self.get_screen_offset()
        ox = self.config.get("calibration_offset_x", 0)
        oy = self.config.get("calibration_offset_y", 0)

        for seq in self.config.get("sequences", []):
            if not self.running or self.paused:
                break
            self._run_seq(seq, det_map, scr_x, scr_y, ox, oy, depth=0)

    def _run_seq(self, seq: dict, det_map: dict, scr_x: int, scr_y: int,
                 ox: int, oy: int, depth: int = 0) -> None:
        if not seq.get("enabled", True) or not self.running or self.paused:
            return
        indent = "  " * depth
        if not self._check_conditions(seq, det_map):
            return

        self._log(f"{indent}Exec: {seq['name']}", "info")
        self._execute_steps(seq, det_map, scr_x, scr_y, ox, oy)
        bus.emit("sequencer.sequence_done", seq.get("name", ""))

        for child in seq.get("children", []):
            if not self.running or self.paused:
                return
            self._run_seq(child, det_map, scr_x, scr_y, ox, oy, depth + 1)

    def _check_conditions(self, seq: dict, det_map: dict) -> bool:
        for cond in seq.get("conditions", []):
            tpl = cond.get("template", "")
            mode = cond.get("mode", "absent")
            detected = tpl in det_map and len(det_map[tpl]) > 0
            if mode == "absent" and detected:
                return False
            if mode == "present" and not detected:
                return False
        return True

    def _execute_steps(self, seq: dict, det_map: dict,
                       scr_x: int, scr_y: int, ox: int, oy: int) -> bool:
        hover_ms = self.config.get("hover_delay_ms", 150)
        action_ms = self.config.get("action_delay_ms", 300)
        last_match: Optional[tuple] = None

        for i, step in enumerate(seq.get("steps", [])):
            if not self.running or self.paused:
                return False
            stype = step.get("type", "")
            tpl_tid = step.get("template", "")
            val = step.get("value", "")
            try:
                result = self._exec_step(
                    stype, tpl_tid, val, step, det_map,
                    scr_x, scr_y, ox, oy,
                    hover_ms, action_ms, last_match, i, seq,
                )
                if result is None:
                    return False
                elif isinstance(result, tuple):
                    last_match = result
                bus.emit("sequencer.step_executed", seq.get("name",""), i, stype)
            except Exception as e:
                self._log(f"  Step {i+1} erreur: {e}", "error")
                return False
            time.sleep(0.03)
        return True

    def _exec_step(self, stype, tpl_tid, val, step, det_map,
                   scr_x, scr_y, ox, oy,
                   hover_ms, action_ms, last_match, idx, seq) -> Any:

        if stype == "detect":
            if tpl_tid in det_map and det_map[tpl_tid]:
                m = det_map[tpl_tid][0]
                self._log(f"  {idx+1}: detect '{tpl_tid}' OK ({m[4]:.0%})", "ok")
                return m
            self._log(f"  {idx+1}: detect '{tpl_tid}' absent", "warn")
            return None

        elif stype == "hover":
            if last_match and IS_WINDOWS:
                cx = scr_x + last_match[0] + last_match[2] // 2 + ox
                cy = scr_y + last_match[1] + last_match[3] // 2 + oy
                _set_cursor(cx, cy)
                time.sleep(hover_ms / 1000.0)
            return last_match

        elif stype in ("click_gauche", "click_droit"):
            if last_match and IS_WINDOWS:
                cx = scr_x + last_match[0] + last_match[2] // 2 + ox
                cy = scr_y + last_match[1] + last_match[3] // 2 + oy
                btn = "left" if stype == "click_gauche" else "right"
                _mouse_click(cx, cy, btn)
                time.sleep(action_ms / 1000.0)
            return last_match

        elif stype in ("detect_then_click", "detect_then_rclick"):
            if tpl_tid in det_map and det_map[tpl_tid]:
                m = det_map[tpl_tid][0]
                if IS_WINDOWS:
                    cx = scr_x + m[0] + m[2] // 2 + ox
                    cy = scr_y + m[1] + m[3] // 2 + oy
                    _set_cursor(cx, cy)
                    time.sleep(hover_ms / 1000.0)
                    btn = "left" if stype == "detect_then_click" else "right"
                    _mouse_click(cx, cy, btn)
                    time.sleep(action_ms / 1000.0)
                self._log(f"  {idx+1}: {stype} '{tpl_tid}' OK", "ok")
                return m
            self._log(f"  {idx+1}: {stype} '{tpl_tid}' introuvable", "warn")
            return None

        elif stype == "wait":
            ms = int(val) if val and val.isdigit() else action_ms
            time.sleep(ms / 1000.0)
            return last_match

        elif stype == "touche":
            if HAS_KEYBOARD:
                kb_module.press_and_release(val if val else "&")
                time.sleep(0.1)
            return last_match

        elif stype == "combo_touches":
            if HAS_KEYBOARD and val:
                kb_module.press_and_release(val)
                time.sleep(0.1)
            return last_match

        elif stype == "bind_slot":
            if HAS_KEYBOARD:
                slot = val.strip() if val else "1"
                key = SLOT_KEYS_AZERTY.get(slot, slot)
                kb_module.press_and_release(key)
                time.sleep(0.15)
            return last_match

        elif stype == "clic_position":
            if IS_WINDOWS and val:
                try:
                    parts = val.replace(" ", "").split(",")
                    px, py = int(parts[0]), int(parts[1])
                    _mouse_click(scr_x + px + ox, scr_y + py + oy, "left")
                    time.sleep(action_ms / 1000.0)
                    return (px, py, 0, 0, 1.0)
                except (ValueError, IndexError) as e:
                    self._log(f"  {idx+1}: erreur position: {e}", "error")
                    return None
            return last_match

        elif stype == "clic_grille":
            if IS_WINDOWS and val:
                try:
                    parts = val.replace(" ", "").split(",")
                    col, row = int(parts[0]), int(parts[1])
                    grid = self.config.get("grid", {})
                    orig_x = grid.get("origin_x", 0)
                    orig_y = grid.get("origin_y", 0)
                    cw = grid.get("cell_w", 43)
                    ch = grid.get("cell_h", 22)
                    gpx = orig_x + (col - row) * cw // 2
                    gpy = orig_y + (col + row) * ch // 2
                    _mouse_click(scr_x + gpx + ox, scr_y + gpy + oy, "left")
                    time.sleep(action_ms / 1000.0)
                    return (gpx, gpy, 0, 0, 1.0)
                except (ValueError, IndexError) as e:
                    self._log(f"  {idx+1}: erreur grille: {e}", "error")
                    return None
            return last_match

        elif stype == "attendre_detection":
            timeout_ms = int(val) if val and val.isdigit() else 10000
            start = time.time()
            while time.time() - start < timeout_ms / 1000.0:
                if not self.running or self.paused:
                    return None
                dm = self.get_det_map()
                if tpl_tid in dm and dm[tpl_tid]:
                    self._log(f"  {idx+1}: '{tpl_tid}' apparu", "ok")
                    return dm[tpl_tid][0]
                time.sleep(0.2)
            self._log(f"  {idx+1}: timeout attente '{tpl_tid}'", "warn")
            return None

        elif stype == "attendre_disparition":
            timeout_ms = int(val) if val and val.isdigit() else 10000
            start = time.time()
            while time.time() - start < timeout_ms / 1000.0:
                if not self.running or self.paused:
                    return None
                dm = self.get_det_map()
                if tpl_tid not in dm or not dm[tpl_tid]:
                    self._log(f"  {idx+1}: '{tpl_tid}' disparu", "ok")
                    return last_match
                time.sleep(0.2)
            self._log(f"  {idx+1}: timeout disparition '{tpl_tid}'", "warn")
            return None

        elif stype == "pause_si_present":
            if tpl_tid in det_map and det_map[tpl_tid]:
                self.paused = True
                self._log("  Auto-pause (template detecte)", "warn")
                bus.emit("sequencer.state_changed", "paused")
                return None
            return last_match

        elif stype in ("sous_sequence", "si_detecte_alors", "si_absent_alors"):
            sub_id = step.get("sub_sequence_id")
            if not sub_id:
                return last_match
            if stype == "si_detecte_alors":
                if not (tpl_tid in det_map and det_map[tpl_tid]):
                    return last_match
            elif stype == "si_absent_alors":
                if tpl_tid in det_map and det_map[tpl_tid]:
                    return last_match
            sub = self._find_seq_by_id(sub_id, self.config.get("sequences", []))
            if sub:
                scr_x2, scr_y2 = self.get_screen_offset()
                self._execute_steps(sub, det_map, scr_x2, scr_y2, ox, oy)
            return last_match

        return last_match

    def _find_seq_by_id(self, sid: int, seqs: list) -> Optional[dict]:
        for s in seqs:
            if s.get("id") == sid:
                return s
            found = self._find_seq_by_id(sid, s.get("children", []))
            if found:
                return found
        return None
