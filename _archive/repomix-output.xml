"""Moteur de detection par template matching OpenCV.

Version: 1.0.0
NE PAS MODIFIER une fois verrouille.

Charge les templates depuis un dossier, effectue le matching
multi-echelle sur une frame BGR, et retourne les DetectionResult.
"""
from __future__ import annotations
import cv2
import numpy as np
from pathlib import Path
from dataclasses import dataclass
from vision_automator_v5.shared.logger import get_logger

log = get_logger("detection_engine")


@dataclass
class Template:
    """Un template charge en memoire."""
    name: str
    category: str
    image: np.ndarray       # BGR
    mask: np.ndarray | None  # optionnel, grayscale
    w: int
    h: int


class DetectionEngine:
    """Charge des templates et detecte via matchTemplate."""

    def __init__(self):
        self.templates: list[Template] = []

    def load_templates(self, folder: str | Path) -> int:
        """Charge tous les templates depuis un dossier structure:
        folder/
          category_name/
            template_name/
              variant_0.png
              variant_0_mask.png  (optionnel)
        Retourne le nombre de templates charges.
        """
        folder = Path(folder)
        if not folder.exists():
            log.warning(f"Dossier templates inexistant: {folder}")
            return 0

        self.templates.clear()
        count = 0

        for category_dir in sorted(folder.iterdir()):
            if not category_dir.is_dir():
                continue
            category = category_dir.name

            for template_dir in sorted(category_dir.iterdir()):
                if not template_dir.is_dir():
                    # Fichier image direct dans la categorie
                    if template_dir.suffix.lower() in (".png", ".jpg", ".bmp"):
                        tpl = self._load_single(template_dir, category)
                        if tpl:
                            self.templates.append(tpl)
                            count += 1
                    continue

                template_name = template_dir.name
                # Charger toutes les variantes
                for img_path in sorted(template_dir.glob("variant_*.png")):
                    if "_mask" in img_path.stem:
                        continue
                    tpl = self._load_single(img_path, category, template_name)
                    if tpl:
                        self.templates.append(tpl)
                        count += 1

        log.info(f"{count} templates charges depuis {folder}")
        return count

    def _load_single(
        self, img_path: Path, category: str, name: str | None = None
    ) -> Template | None:
        """Charge une image + son masque optionnel."""
        img = cv2.imread(str(img_path), cv2.IMREAD_COLOR)
        if img is None:
            log.warning(f"Impossible de lire: {img_path}")
            return None

        h, w = img.shape[:2]
        tpl_name = name or img_path.stem

        # Chercher le masque
        mask_path = img_path.with_name(img_path.stem + "_mask.png")
        mask = None
        if mask_path.exists():
            mask = cv2.imread(str(mask_path), cv2.IMREAD_GRAYSCALE)
            if mask is not None and mask.shape[:2] != (h, w):
                mask = cv2.resize(mask, (w, h))

        return Template(
            name=tpl_name,
            category=category,
            image=img,
            mask=mask,
            w=w,
            h=h,
        )

    def detect(
        self,
        frame_bgr: np.ndarray,
        threshold: float = 0.75,
        nms_overlap: float = 0.4,
    ) -> list[dict]:
        """Detecte tous les templates dans la frame.

        Retourne une liste de dict:
            {template_name, category, x, y, w, h, confidence}
        """
        if frame_bgr is None or len(self.templates) == 0:
            return []

        frame_gray = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2GRAY)
        raw_hits: list[dict] = []

        for tpl in self.templates:
            tpl_gray = cv2.cvtColor(tpl.image, cv2.COLOR_BGR2GRAY)

            method = cv2.TM_CCORR_NORMED if tpl.mask is not None else cv2.TM_CCOEFF_NORMED

            try:
                result = cv2.matchTemplate(
                    frame_gray, tpl_gray,
                    method,
                    mask=tpl.mask,
                )
            except cv2.error as e:
                log.debug(f"matchTemplate erreur pour {tpl.name}: {e}")
                continue

            locations = np.where(result >= threshold)

            for pt_y, pt_x in zip(*locations):
                conf = float(result[pt_y, pt_x])
                raw_hits.append({
                    "template_name": tpl.name,
                    "category": tpl.category,
                    "x": int(pt_x),
                    "y": int(pt_y),
                    "w": tpl.w,
                    "h": tpl.h,
                    "confidence": round(conf, 4),
                })

        # NMS — supprimer les doublons qui se chevauchent
        if raw_hits:
            raw_hits = self._nms(raw_hits, nms_overlap)

        return raw_hits

    def _nms(self, hits: list[dict], overlap_thresh: float) -> list[dict]:
        """Non-Maximum Suppression simple sur les boites."""
        if not hits:
            return hits

        boxes = np.array([[h["x"], h["y"], h["x"] + h["w"], h["y"] + h["h"]] for h in hits])
        scores = np.array([h["confidence"] for h in hits])

        x1, y1, x2, y2 = boxes[:, 0], boxes[:, 1], boxes[:, 2], boxes[:, 3]
        areas = (x2 - x1) * (y2 - y1)
        order = scores.argsort()[::-1]

        keep: list[int] = []
        while order.size > 0:
            i = order[0]
            keep.append(i)

            xx1 = np.maximum(x1[i], x1[order[1:]])
            yy1 = np.maximum(y1[i], y1[order[1:]])
            xx2 = np.minimum(x2[i], x2[order[1:]])
            yy2 = np.minimum(y2[i], y2[order[1:]])

            inter = np.maximum(0, xx2 - xx1) * np.maximum(0, yy2 - yy1)
            iou = inter / (areas[i] + areas[order[1:]] - inter + 1e-6)

            inds = np.where(iou <= overlap_thresh)[0]
            order = order[inds + 1]

        return [hits[i] for i in keep]
