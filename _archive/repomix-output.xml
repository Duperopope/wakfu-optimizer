"""Event Bus — communication inter-modules par publish/subscribe.

NE PAS MODIFIER une fois verrouille.
Version: 1.0.0

Usage:
    from vision_automator_v5.shared.bus import bus

    # Module Capture publie:
    bus.emit("frame.new", frame_data)

    # Module Detection ecoute:
    bus.on("frame.new", self.on_new_frame)

    # Se desabonner:
    bus.off("frame.new", self.on_new_frame)
"""
from __future__ import annotations
from typing import Any, Callable
from collections import defaultdict
from vision_automator_v5.shared.logger import get_logger

log = get_logger("bus")


class EventBus:
    """Bus d'evenements synchrone thread-safe pour communication inter-modules."""

    def __init__(self):
        self._listeners: dict[str, list[Callable]] = defaultdict(list)
        self._once: dict[str, list[Callable]] = defaultdict(list)

    def on(self, event: str, callback: Callable) -> None:
        """S'abonner a un evenement."""
        if callback not in self._listeners[event]:
            self._listeners[event].append(callback)
            log.debug(f"+ {callback.__qualname__} ecoute '{event}'")

    def once(self, event: str, callback: Callable) -> None:
        """S'abonner a un evenement pour une seule fois."""
        self._once[event].append(callback)

    def off(self, event: str, callback: Callable) -> None:
        """Se desabonner d'un evenement."""
        if callback in self._listeners[event]:
            self._listeners[event].remove(callback)

    def emit(self, event: str, *args: Any, **kwargs: Any) -> None:
        """Emettre un evenement vers tous les abonnes."""
        for cb in self._listeners.get(event, []):
            try:
                cb(*args, **kwargs)
            except Exception as e:
                log.error(f"Erreur dans listener {cb.__qualname__} pour '{event}': {e}")

        # Listeners one-shot
        for cb in self._once.pop(event, []):
            try:
                cb(*args, **kwargs)
            except Exception as e:
                log.error(f"Erreur dans once-listener pour '{event}': {e}")

    def clear(self) -> None:
        """Supprimer tous les abonnements."""
        self._listeners.clear()
        self._once.clear()

    def list_events(self) -> list[str]:
        """Liste tous les evenements avec au moins un abonne."""
        return [e for e, cbs in self._listeners.items() if cbs]


# Instance globale unique — importee par tous les modules
bus = EventBus()
